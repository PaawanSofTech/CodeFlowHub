#include <bits/stdc++.h>
using namespace std;

int maximumCoordinate(int input1, int input2, int input3[], int input4[])
{
    int n = input1;
    int coins = input2;

    vector<pair<int, int>> cp;

    for (int i = 0; i < n; i++)
    {
        cp.push_back({input3[i], input4[i]});
    }

    sort(cp.begin(), cp.end());

    int pos = 0;

    for (auto &cp : cp)
    {
        int nextPos = cp.first;
        int reward = cp.second;

        int cost = nextPos - pos;

        if (coins >= cost)
        {
            coins -= cost;
            coins += reward;
            pos = nextPos;
        }
        else
        {
            return pos + coins;
        }
    }

    return pos + coins;
}

int main()
{
    int n, k;
    cin >> n >> k;

    int A[n], B[n];

    for (int i = 0; i < n; i++)
        cin >> A[i];

    for (int i = 0; i < n; i++)
        cin >> B[i];

    int result = maximumCoordinate(n, k, A, B);

    cout << result << endl;

    return 0;
}