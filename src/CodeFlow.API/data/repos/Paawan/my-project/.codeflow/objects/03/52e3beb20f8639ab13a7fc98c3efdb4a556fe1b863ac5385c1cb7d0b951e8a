#include <stdio.h>
#include <string.h>
#include <string>
using namespace std;

int moneyConversion(string input1)
{
    long long MOD = 10000007;

    long long val = 0;
    char currency = 0;

    int i = 0;
    while (i < input1.size() && (isdigit(input1[i]) || input1[i] == ' ')) {
        if (isdigit(input1[i])) {
            val = val * 10 + (input1[i] - '0');
        }
        i++;
    }
    while (i < input1.size() && input1[i] == ' ') i++;
    if (i < input1.size()) currency = input1[i];

    long long r = 0;
    if (currency == 'Y') r = 10;
    else if (currency == 'P') r = 100;
    else if (currency == 'D') r = 70;
    else if (currency == 'R') r = 1;

    long long res = (val % MOD * r) % MOD;

    return (int)res;
}

int main()
{
    string input;
    getline(cin, input);

    cout << moneyConversion(input);

    return 0;
}