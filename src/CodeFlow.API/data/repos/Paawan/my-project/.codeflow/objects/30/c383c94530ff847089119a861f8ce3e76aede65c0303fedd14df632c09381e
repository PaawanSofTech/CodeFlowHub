#include <iostream>
#include <string>
#include <algorithm>

using namespace std;

string validotp(string input1) {
    int n = input1.size();
    if (n == 0) return "0";
    
    long long count = 0;

    for (int len = 2; len < n; len += 2) {
        int k = len / 2;
        long long current_power = 1;
        for (int i = 0; i < k - 1; i++) current_power *= 10;
        count += 9 * current_power;
    }

    if (n % 2 == 0) {
        int k = n / 2;
        string prefix = input1.substr(0, k);
        string suffix = input1.substr(k);

        long long prefixNum = stoll(prefix);
        
        long long start = 1;
        for (int i = 0; i < k - 1; i++) start *= 10;

        if (prefix <= suffix) {
            count += (prefixNum - start + 1);
        } else {
            count += (prefixNum - start);
        }
    }

    return to_string(count);
}

int main() {

    string input1;
    if (!(cin >> input1)) return 0;

    cout << validotp(input1) << endl;
    return 0;
}